# CV: vendored third-party libs and model checkpoints (multi-GB)
# Includes Mask3D source tree, MinkowskiEngine compiled extension, and the
# Mask3D/SAM/GroundingDINO weights at opt/checkpoints/.
opt/

# CV: raw phone scans, LiDAR captures, and pipeline visualization meshes.
# These are large per-room blobs (LAS, OBJ, PLY) regenerated per scan session.
server_room_phone/

# CV: native deb packages occasionally dropped here for CUDA installs.
frontend/*.deb

# CV: Mask3D label preview meshes — regenerated from train/*.npy by
# scripts/apply_mask3d_label_overrides.py. The .npy itself IS tracked.
data/mask3d_server_room/previews/